# =============================================================================
# AssetBox Workers Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# Kafka (Event Streaming)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=assetbox-workers
KAFKA_GROUP_ID=assetbox-consumers

# Meilisearch (Search Indexer)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev_master_key_change_in_production

# Email (Resend — Email Notification Worker)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000
